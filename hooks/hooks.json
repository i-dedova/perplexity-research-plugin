{
  "description": "Hooks for perplexity-research plugin",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/check-research-agent.js",
            "timeout": 90
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "research-agent",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/inject-templates.js",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "research-agent",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/extract-research-output.js",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
